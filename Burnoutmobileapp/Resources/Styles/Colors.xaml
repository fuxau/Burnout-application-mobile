<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Call of Phoenix Theme Colors -->
    
    <!-- Primary Blue -->
    <Color x:Key="Primary">#005da1</Color>
    <Color x:Key="PrimaryLight">#1a6eaf</Color>
    <Color x:Key="PrimaryDark">#004d88</Color>
    
    <!-- Background Colors -->
    <Color x:Key="BackgroundDark">#0a1628</Color>
    <Color x:Key="BackgroundLight">#F8F7F5</Color>
    
    <!-- Surface Colors -->
    <Color x:Key="SurfaceDark">#0d1f3c</Color>
    <Color x:Key="SurfaceDark2">#112447</Color>
    <Color x:Key="SurfaceLight">#FFFFFF</Color>
    <Color x:Key="SurfaceBorder">#1a3a6b</Color>
    <Color x:Key="InputBackground">#0f1e38</Color>
    
    <!-- Text Colors -->
    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#9CA3AF</Color>
    <Color x:Key="TextMuted">#6B7280</Color>
    <Color x:Key="TextDark">#111418</Color>
    
    <!-- Status Colors -->
    <Color x:Key="Success">#22C55E</Color>
    <Color x:Key="SuccessLight">#22C55E1A</Color>
    <Color x:Key="Error">#EF4444</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    
    <!-- Basic Colors -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Transparent">Transparent</Color>
    
    <!-- Gray Scale -->
    <Color x:Key="Gray100">#F3F4F6</Color>
    <Color x:Key="Gray200">#E5E7EB</Color>
    <Color x:Key="Gray300">#D1D5DB</Color>
    <Color x:Key="Gray400">#9CA3AF</Color>
    <Color x:Key="Gray500">#6B7280</Color>
    <Color x:Key="Gray600">#4B5563</Color>
    <Color x:Key="Gray700">#374151</Color>
    <Color x:Key="Gray800">#1F2937</Color>
    <Color x:Key="Gray900">#111827</Color>
    <Color x:Key="Gray950">#030712</Color>
    
    <!-- Missing colors required by Styles.xaml -->
    <Color x:Key="MidnightBlue">#003d6e</Color>
    <Color x:Key="OffBlack">#071020</Color>
    <Color x:Key="Magenta">#005da1</Color>
    <Color x:Key="Secondary">#005da1</Color>
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>
    <Color x:Key="SecondaryDarkText">#E5E7EB</Color>
    
    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="BackgroundDarkBrush" Color="{StaticResource BackgroundDark}"/>
    <SolidColorBrush x:Key="SurfaceDarkBrush" Color="{StaticResource SurfaceDark}"/>
    <SolidColorBrush x:Key="SurfaceBorderBrush" Color="{StaticResource SurfaceBorder}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="TransparentBrush" Color="{StaticResource Transparent}"/>
    
</ResourceDictionary>