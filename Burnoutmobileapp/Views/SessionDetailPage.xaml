<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Burnoutmobileapp.Views.SessionDetailPage"
             BackgroundColor="#0a1628"
             Shell.TabBarIsVisible="False"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <Grid Padding="16,52,16,16" ColumnDefinitions="Auto,*,Auto" BackgroundColor="#0a1628">
                    <Border StrokeThickness="1" Stroke="#1a3a6b" StrokeShape="RoundRectangle 20"
                            BackgroundColor="#0d1f3c" HeightRequest="40" WidthRequest="40">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="&#8592;" FontSize="20" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label x:Name="TitleLabel" Grid.Column="1" Text="Seance"
                           FontSize="20" FontAttributes="Bold" TextColor="White"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                    <BoxView Grid.Column="2" WidthRequest="40" Color="Transparent"/>
                </Grid>

                <Border Margin="16,0,16,16" StrokeThickness="0" StrokeShape="RoundRectangle 16"
                        BackgroundColor="#0d1f3c" Padding="20">
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="ProgramLabel" FontSize="12" TextColor="#6B7280"/>
                        <Label x:Name="SessionTitleLabel" FontSize="22" FontAttributes="Bold" TextColor="White"/>
                        <HorizontalStackLayout Spacing="8" x:Name="BadgesRow"/>
                        <BoxView HeightRequest="1" Color="#1a3a6b" Margin="0,4"/>
                        <Grid ColumnDefinitions="*,*">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="HEURE" FontSize="10" TextColor="#6B7280"/>
                                <Label x:Name="TimeLabel" FontSize="16" FontAttributes="Bold" TextColor="White"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="COACH" FontSize="10" TextColor="#6B7280"/>
                                <Label x:Name="CoachLabel" FontSize="16" FontAttributes="Bold" TextColor="White"/>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Label Text="Exercices" Padding="16,0,16,12"
                       FontSize="18" FontAttributes="Bold" TextColor="White"/>

                <VerticalStackLayout x:Name="BlocksContainer" Padding="16,0,16,16" Spacing="12"/>

                <BoxView HeightRequest="16" Color="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="1" BackgroundColor="#071020" StrokeThickness="0" Padding="16,12,16,28">
            <Button x:Name="LancerButton" Text="Lancer la seance"
                    BackgroundColor="#005da1" TextColor="White"
                    FontSize="17" FontAttributes="Bold"
                    HeightRequest="56" CornerRadius="28"
                    HorizontalOptions="Fill"
                    Clicked="OnLancerClicked"/>
        </Border>

    </Grid>
</ContentPage>