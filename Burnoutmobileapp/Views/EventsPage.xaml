<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Burnoutmobileapp.ViewModels"
             x:Class="Burnoutmobileapp.Views.EventsPage"
             BackgroundColor="#0a1628"
             Shell.TabBarIsVisible="False"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- Header -->
                <Grid Padding="16,52,16,16" ColumnDefinitions="*,Auto" BackgroundColor="#0a1628">
                    <Label Text="Mes activites"
                           FontSize="28" FontAttributes="Bold" TextColor="White"
                           VerticalOptions="Center"/>
                    <Border Grid.Column="1" StrokeThickness="1" Stroke="#1a3a6b"
                            StrokeShape="RoundRectangle 20" BackgroundColor="#0d1f3c"
                            HeightRequest="40" WidthRequest="40">
                        <Label Text="&#128197;" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- Week Date Picker -->
                <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,0,0,8" BackgroundColor="#0a1628">
                    <!-- Prev week button -->
                    <Border Grid.Column="0" StrokeThickness="0" BackgroundColor="Transparent"
                            HeightRequest="44" WidthRequest="44" Margin="4,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPrevWeekTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="&#8249;" FontSize="32" FontAttributes="Bold"
                               TextColor="#005da1" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <!-- Days row -->
                    <ScrollView Grid.Column="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout x:Name="DaysContainer" Spacing="4" Padding="4,0"/>
                    </ScrollView>

                    <!-- Next week button -->
                    <Border Grid.Column="2" StrokeThickness="0" BackgroundColor="Transparent"
                            HeightRequest="44" WidthRequest="44" Margin="4,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNextWeekTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="&#8250;" FontSize="32" FontAttributes="Bold"
                               TextColor="#005da1" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- Sessions for selected day -->
                <VerticalStackLayout Padding="16,16,16,0" Spacing="4">
                    <Label Text="Seances du jour"
                           FontSize="18" FontAttributes="Bold" TextColor="White"/>
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="SessionsContainer" Padding="16,12,16,16" Spacing="12"/>

                <!-- No session label -->
                <Label x:Name="NoSessionLabel"
                       Text="Aucune seance ce jour"
                       FontSize="15" TextColor="#6B7280"
                       HorizontalOptions="Center"
                       Padding="16,8,16,16"
                       IsVisible="False"/>

                <!-- Separator -->
                <BoxView HeightRequest="1" Color="#1a3a6b" Margin="16,8"/>

                <!-- Challenge Progress Section -->
                <VerticalStackLayout Padding="16,8,16,0" Spacing="4">
                    <Label Text="Progression du defi"
                           FontSize="18" FontAttributes="Bold" TextColor="White"/>
                </VerticalStackLayout>

                <!-- Days Grid (challenge calendar) -->
                <FlexLayout Wrap="Wrap"
                            JustifyContent="Start"
                            AlignItems="Start"
                            Padding="13,8,13,8"
                            BindableLayout.ItemsSource="{Binding DayItems}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:DayItem">
                            <Border HeightRequest="44" WidthRequest="44" Margin="3"
                                    StrokeShape="RoundRectangle 22"
                                    BackgroundColor="#0d1f3c"
                                    Stroke="{Binding StrokeBrush}"
                                    StrokeThickness="2">
                                <Label HorizontalOptions="Center" VerticalOptions="Center"
                                       Text="{Binding DisplayText}"
                                       TextColor="{Binding DisplayColor}"
                                       FontSize="{Binding DisplayFontSize}"
                                       FontAttributes="{Binding DisplayFontAttributes}"/>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>

                <!-- Progress Card -->
                <Border Margin="16,8,16,16" StrokeThickness="0" StrokeShape="RoundRectangle 16"
                        BackgroundColor="#0d1f3c" Padding="20">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Progression"
                                   FontSize="16" FontAttributes="Bold" TextColor="White"/>
                            <Label Grid.Column="1"
                                   Text="{Binding ProgressPercent, StringFormat='{0:F0}%'}"
                                   FontSize="16" FontAttributes="Bold" TextColor="#005da1"/>
                        </Grid>
                        <Grid HeightRequest="8">
                            <BoxView BackgroundColor="#1a3a6b" CornerRadius="4" HorizontalOptions="Fill" VerticalOptions="Fill"/>
                            <BoxView BackgroundColor="#005da1" CornerRadius="4" HorizontalOptions="Start"
                                     VerticalOptions="Fill" WidthRequest="{Binding ProgressBarWidth}"/>
                        </Grid>
                        <Label Text="{Binding RemainingDays, StringFormat='{0} jours restants'}"
                               FontSize="12" TextColor="#6B7280" HorizontalOptions="End"/>
                    </VerticalStackLayout>
                </Border>

                <BoxView HeightRequest="24" Color="Transparent"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Custom Footer Tab Bar -->
        <Border Grid.Row="1" BackgroundColor="#071020" StrokeThickness="0" Padding="0">
            <Grid ColumnDefinitions="*,*,*,*,*" HeightRequest="88" Padding="0,0,0,20">
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAccueilTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="&#127968;" FontSize="24" HorizontalOptions="Center"/>
                    <Label Text="Accueil" FontSize="10" TextColor="#6B7280" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" HorizontalOptions="Center" Spacing="4">
                    <Label Text="&#128197;" FontSize="24" HorizontalOptions="Center"/>
                    <Label Text="Agenda" FontSize="10" FontAttributes="Bold" TextColor="#005da1" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="Center" Spacing="4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFeedTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="&#127942;" FontSize="24" HorizontalOptions="Center"/>
                    <Label Text="Feed" FontSize="10" TextColor="#6B7280" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="3" VerticalOptions="Center" HorizontalOptions="Center" Spacing="4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCoachTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="&#128170;" FontSize="24" HorizontalOptions="Center"/>
                    <Label Text="Coach" FontSize="10" TextColor="#6B7280" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="4" VerticalOptions="Center" HorizontalOptions="Center" Spacing="4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnProfilTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="&#128100;" FontSize="24" HorizontalOptions="Center"/>
                    <Label Text="Profil" FontSize="10" TextColor="#6B7280" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

    </Grid>
</ContentPage>