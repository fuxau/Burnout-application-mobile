<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Burnoutmobileapp.Views.LoginPage"
             BackgroundColor="#0a1628">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20" VerticalOptions="Center">
            
            <!-- Logo Section -->
            <VerticalStackLayout Spacing="16" HorizontalOptions="Center" Margin="0,60,0,30">
                <Label Text="🔥" 
                       FontSize="80" 
                       HorizontalOptions="Center"/>
                
                <Label Text="Call of Phoenix"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="#005da1"
                       HorizontalOptions="Center"/>
                
                <Label Text="RISE • TRAIN • TRANSCEND"
                       FontSize="12"
                       TextColor="#9CA3AF"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Login Form -->
            <VerticalStackLayout Spacing="16" Margin="0,20,0,0">
                
                <!-- Email Field -->
                <Border StrokeThickness="1"
                        Stroke="#005da166"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="#0d1f3c"
                        HeightRequest="56">
                    <Grid ColumnDefinitions="50,*">
                        <Label Text="📧" 
                               FontSize="20"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"/>
                        <Entry Grid.Column="1"
                               x:Name="EmailEntry"
                               Placeholder="Adresse email"
                               PlaceholderColor="#FFFFFF50"
                               TextColor="White"
                               Keyboard="Email"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Password Field -->
                <Border StrokeThickness="1"
                        Stroke="#005da166"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="#0d1f3c"
                        HeightRequest="56">
                    <Grid ColumnDefinitions="50,*">
                        <Label Text="🔒" 
                               FontSize="20"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"/>
                        <Entry Grid.Column="1"
                               x:Name="PasswordEntry"
                               Placeholder="Mot de passe"
                               PlaceholderColor="#FFFFFF50"
                               TextColor="White"
                               IsPassword="True"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Login Button -->
                <Button Text="Se connecter"
                        x:Name="LoginButton"
                        Clicked="OnLoginClicked"
                        BackgroundColor="#005da1"
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold"
                        HeightRequest="56"
                        CornerRadius="12"
                        Margin="0,16,0,0"/>
            </VerticalStackLayout>

            <!-- Sign Up Link -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,30,0,0">
                <Label Text="Pas encore membre ?"
                       TextColor="#9CA3AF"
                       FontSize="14"/>
                <Label Text="Rejoindre le Phoenix"
                       TextColor="#005da1"
                       FontSize="14"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRegisterTapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
