<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Burnoutmobileapp.ViewModels"
             x:Class="Burnoutmobileapp.Views.EventDetailPage"
             x:DataType="viewmodels:EventDetailViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BackgroundDark}">

    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <Grid RowDefinitions="350,*">
                
                <!-- Hero Image -->
                <Grid>
                    <Image Source="{Binding Event.ImageUrl}" 
                           Aspect="AspectFill"
                           HeightRequest="350"/>
                    
                    <!-- Gradient Overlay -->
                    <BoxView>
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#80000000" Offset="0.0"/>
                                <GradientStop Color="Transparent" Offset="0.4"/>
                                <GradientStop Color="#CC231A0F" Offset="0.8"/>
                                <GradientStop Color="{StaticResource BackgroundDark}" Offset="1.0"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>
                    
                    <!-- Top Navigation -->
                    <Grid Padding="16,50,16,0" ColumnDefinitions="Auto,*,Auto" VerticalOptions="Start">
                        <Border StrokeThickness="1"
                                Stroke="#FFFFFF20"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="#33000000"
                                HeightRequest="40"
                                WidthRequest="40">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="←" FontSize="20" TextColor="{StaticResource White}" 
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        
                        <Border Grid.Column="2"
                                StrokeThickness="1"
                                Stroke="#FFFFFF20"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="#33000000"
                                HeightRequest="40"
                                WidthRequest="40">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ShareCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="↗" FontSize="18" TextColor="{StaticResource White}" 
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                    
                    <!-- Hero Text -->
                    <VerticalStackLayout VerticalOptions="End" Padding="20,0,20,16" Spacing="8">
                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 6"
                                BackgroundColor="{StaticResource Primary}"
                                Padding="10,4"
                                HorizontalOptions="Start">
                            <Label Text="{Binding Event.Category, StringFormat='{0} &amp; Flexibilité'}"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource White}"/>
                        </Border>
                        
                        <Label Text="{Binding Event.Title}"
                               FontSize="32"
                               FontAttributes="Bold"
                               TextColor="{StaticResource White}"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- Content -->
                <VerticalStackLayout Grid.Row="1" Padding="20,0" Spacing="24">
                    
                    <!-- Instructor Section -->
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,0,0,16">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer/>
                        </Grid.GestureRecognizers>
                        
                        <Grid>
                            <Border StrokeThickness="2"
                                    Stroke="{StaticResource SurfaceDark}"
                                    StrokeShape="RoundRectangle 24"
                                    HeightRequest="48"
                                    WidthRequest="48">
                                <Image Source="{Binding Event.Coach.ImageUrl}" Aspect="AspectFill"/>
                            </Border>
                            
                            <!-- PRO Badge -->
                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource BackgroundDark}"
                                    StrokeShape="RoundRectangle 8"
                                    BackgroundColor="{StaticResource Primary}"
                                    HeightRequest="16"
                                    WidthRequest="28"
                                    HorizontalOptions="End"
                                    VerticalOptions="End"
                                    Margin="0,0,-4,-4">
                                <Label Text="PRO" FontSize="8" FontAttributes="Bold" 
                                       TextColor="{StaticResource White}"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                        </Grid>
                        
                        <VerticalStackLayout Grid.Column="1" Margin="12,0" VerticalOptions="Center">
                            <Label Text="COACH PRINCIPAL"
                                   FontSize="10"
                                   TextColor="{StaticResource Gray400}"/>
                            <Label Text="{Binding Event.Coach.Name}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource White}"/>
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="End">
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="🔥" FontSize="12"/>
                                <Label Text="{Binding Event.Intensity}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}"/>
                            </HorizontalStackLayout>
                            <Label Text="{Binding Event.Level, StringFormat='Niveau {0}'}"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray400}"
                                   HorizontalOptions="End"/>
                        </VerticalStackLayout>
                    </Grid>
                    
                    <BoxView HeightRequest="1" Color="{StaticResource SurfaceBorder}"/>

                    <!-- Date & Location Cards -->
                    <VerticalStackLayout Spacing="12">
                        <!-- Date Card -->
                        <Border StrokeThickness="1"
                                Stroke="{StaticResource SurfaceBorder}"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="{StaticResource SurfaceDark}"
                                Padding="16">
                            <Grid ColumnDefinitions="48,*">
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8"
                                        BackgroundColor="#005da133"
                                        HeightRequest="48"
                                        WidthRequest="48">
                                    <Label Text="📅" FontSize="20" 
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                
                                <VerticalStackLayout Grid.Column="1" Margin="16,0,0,0" VerticalOptions="Center">
                                    <Label Text="DATE &amp; HEURE"
                                           FontSize="10"
                                           TextColor="{StaticResource Gray400}"/>
                                    <Label Text="{Binding Event.FullDateTimeDisplay}"
                                           FontSize="16"
                                           TextColor="{StaticResource White}"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                        
                        <!-- Location Card -->
                        <Border StrokeThickness="1"
                                Stroke="{StaticResource SurfaceBorder}"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="{StaticResource SurfaceDark}"
                                Padding="16">
                            <Grid ColumnDefinitions="48,*">
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8"
                                        BackgroundColor="#005da133"
                                        HeightRequest="48"
                                        WidthRequest="48">
                                    <Label Text="📍" FontSize="20" 
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                
                                <VerticalStackLayout Grid.Column="1" Margin="16,0,0,0" VerticalOptions="Center">
                                    <Label Text="LIEU"
                                           FontSize="10"
                                           TextColor="{StaticResource Gray400}"/>
                                    <Label Text="{Binding Event.LocationDetail}"
                                           FontSize="16"
                                           TextColor="{StaticResource White}"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Map Section -->
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Localisation"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource White}"/>
                            <HorizontalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Ouvrir GPS"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}"/>
                                <Label Text="↗" FontSize="12" TextColor="{StaticResource Primary}"/>
                                <HorizontalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenMapCommand}"/>
                                </HorizontalStackLayout.GestureRecognizers>
                            </HorizontalStackLayout>
                        </Grid>
                        
                        <Border StrokeThickness="1"
                                Stroke="{StaticResource SurfaceBorder}"
                                StrokeShape="RoundRectangle 12"
                                HeightRequest="140"
                                BackgroundColor="{StaticResource SurfaceDark}">
                            <Grid>
                                <Image Source="{Binding Event.ImageUrl}" 
                                       Aspect="AspectFill" 
                                       Opacity="0.5"/>
                                
                                <!-- Map Pin -->
                                <Border StrokeThickness="2"
                                        Stroke="{StaticResource White}"
                                        StrokeShape="RoundRectangle 16"
                                        BackgroundColor="{StaticResource Primary}"
                                        HeightRequest="32"
                                        WidthRequest="32"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center">
                                    <Ellipse Fill="{StaticResource White}" 
                                             HeightRequest="8" 
                                             WidthRequest="8"/>
                                </Border>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Description -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="À propos du cours"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource White}"/>
                        <Label Text="{Binding Event.Description}"
                               FontSize="14"
                               TextColor="{StaticResource Gray300}"
                               LineHeight="1.5"/>
                    </VerticalStackLayout>

                    <!-- Participants -->
                    <VerticalStackLayout Spacing="16" Margin="0,0,0,120">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Participants"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource White}"/>
                            <Border Grid.Column="1"
                                    StrokeThickness="1"
                                    Stroke="{StaticResource SurfaceBorder}"
                                    StrokeShape="RoundRectangle 4"
                                    BackgroundColor="{StaticResource SurfaceDark}"
                                    Padding="8,4">
                                <Label Text="{Binding Event.CurrentParticipants, StringFormat='{0} / 20 places'}"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray300}"/>
                            </Border>
                        </Grid>
                        
                        <Label Text="Les membres du club y vont."
                               FontSize="12"
                               TextColor="{StaticResource Gray400}"
                               VerticalOptions="Center"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Grid>
        </ScrollView>

        <!-- Bottom CTA -->
        <Border Grid.Row="1"
                StrokeThickness="0"
                BackgroundColor="{StaticResource BackgroundDark}"
                Padding="20,16,20,32">
            <Button Command="{Binding RegisterCommand}"
                    Text="Je m'inscris"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="{StaticResource White}"
                    FontSize="18"
                    FontAttributes="Bold"
                    HeightRequest="56"
                    CornerRadius="12">
                <Button.Shadow>
                    <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="20" Opacity="0.3"/>
                </Button.Shadow>
            </Button>
        </Border>
    </Grid>
</ContentPage>
