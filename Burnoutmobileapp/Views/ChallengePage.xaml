<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Burnoutmobileapp.ViewModels"
             x:Class="Burnoutmobileapp.Views.ChallengePage"
             x:DataType="viewmodels:ChallengeViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BackgroundDark}">

    <Grid RowDefinitions="Auto,*,Auto">
        
        <!-- Header -->
        <Grid Padding="16" ColumnDefinitions="Auto,*" BackgroundColor="{StaticResource BackgroundDark}">
            <Border StrokeThickness="1"
                    Stroke="{StaticResource SurfaceBorder}"
                    StrokeShape="RoundRectangle 20"
                    BackgroundColor="{StaticResource SurfaceDark}"
                    HeightRequest="40"
                    WidthRequest="40">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                </Border.GestureRecognizers>
                <Label Text="←" FontSize="20" TextColor="{StaticResource White}" 
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
            
            <Label Grid.Column="1"
                   Text="{Binding Challenge.Title}"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="{StaticResource White}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="24">
                
                <!-- Challenge Image Header -->
                <Border StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        HeightRequest="180">
                    <Grid>
                        <Image Source="{Binding Challenge.ImageUrl}" Aspect="AspectFill"/>
                        <BoxView>
                            <BoxView.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="Transparent" Offset="0.4"/>
                                    <GradientStop Color="#CC000000" Offset="1.0"/>
                                </LinearGradientBrush>
                            </BoxView.Background>
                        </BoxView>
                        
                        <VerticalStackLayout VerticalOptions="End" Padding="16" Spacing="4">
                            <Label Text="{Binding Challenge.Title}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource White}"/>
                            <Label Text="{Binding Challenge.ProgressDisplay}"
                                   FontSize="14"
                                   TextColor="{StaticResource Primary}"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Days Grid -->
                <VerticalStackLayout Spacing="12">
                    <Label Text="Calendrier"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource White}"/>
                    
                    <FlexLayout Wrap="Wrap" 
                                JustifyContent="Start"
                                AlignItems="Start">
                        <!-- Day 1-10 (Completed) -->
                        <Border StrokeThickness="2"
                                Stroke="{StaticResource Primary}"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{StaticResource SurfaceDark}"
                                HeightRequest="40"
                                WidthRequest="40"
                                Margin="4">
                            <Label Text="✓" FontSize="16" FontAttributes="Bold" 
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border StrokeThickness="2"
                                Stroke="{StaticResource Primary}"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{StaticResource SurfaceDark}"
                                HeightRequest="40"
                                WidthRequest="40"
                                Margin="4">
                            <Label Text="✓" FontSize="16" FontAttributes="Bold" 
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border StrokeThickness="2"
                                Stroke="{StaticResource Primary}"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{StaticResource SurfaceDark}"
                                HeightRequest="40"
                                WidthRequest="40"
                                Margin="4">
                            <Label Text="✓" FontSize="16" FontAttributes="Bold" 
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border StrokeThickness="2"
                                Stroke="{StaticResource Primary}"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{StaticResource SurfaceDark}"
                                HeightRequest="40"
                                WidthRequest="40"
                                Margin="4">
                            <Label Text="✓" FontSize="16" FontAttributes="Bold" 
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border StrokeThickness="2"
                                Stroke="{StaticResource Primary}"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{StaticResource SurfaceDark}"
                                HeightRequest="40"
                                WidthRequest="40"
                                Margin="4">
                            <Label Text="✓" FontSize="16" FontAttributes="Bold" 
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border StrokeThickness="2"
                                Stroke="{StaticResource Primary}"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{StaticResource SurfaceDark}"
                                HeightRequest="40"
                                WidthRequest="40"
                                Margin="4">
                            <Label Text="✓" FontSize="16" FontAttributes="Bold" 
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border StrokeThickness="2"
                                Stroke="{StaticResource Primary}"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{StaticResource SurfaceDark}"
                                HeightRequest="40"
                                WidthRequest="40"
                                Margin="4">
                            <Label Text="✓" FontSize="16" FontAttributes="Bold" 
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border StrokeThickness="2"
                                Stroke="{StaticResource Primary}"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{StaticResource SurfaceDark}"
                                HeightRequest="40"
                                WidthRequest="40"
                                Margin="4">
                            <Label Text="✓" FontSize="16" FontAttributes="Bold" 
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border StrokeThickness="2"
                                Stroke="{StaticResource Primary}"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{StaticResource SurfaceDark}"
                                HeightRequest="40"
                                WidthRequest="40"
                                Margin="4">
                            <Label Text="✓" FontSize="16" FontAttributes="Bold" 
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border StrokeThickness="2"
                                Stroke="{StaticResource Primary}"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{StaticResource SurfaceDark}"
                                HeightRequest="40"
                                WidthRequest="40"
                                Margin="4">
                            <Label Text="✓" FontSize="16" FontAttributes="Bold" 
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        
                        <!-- Day 11-12 (Current/Next) -->
                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray600}"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{StaticResource SurfaceDark}"
                                HeightRequest="40"
                                WidthRequest="40"
                                Margin="4">
                            <Label Text="11" FontSize="14" TextColor="{StaticResource Gray400}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray600}"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{StaticResource SurfaceDark}"
                                HeightRequest="40"
                                WidthRequest="40"
                                Margin="4">
                            <Label Text="12" FontSize="14" TextColor="{StaticResource Gray400}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        
                        <!-- Days 13-30 (Remaining) -->
                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray700}"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{StaticResource SurfaceDark}"
                                HeightRequest="40"
                                WidthRequest="40"
                                Margin="4">
                            <Label Text="13" FontSize="14" TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray700}"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{StaticResource SurfaceDark}"
                                HeightRequest="40"
                                WidthRequest="40"
                                Margin="4">
                            <Label Text="14" FontSize="14" TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray700}"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{StaticResource SurfaceDark}"
                                HeightRequest="40"
                                WidthRequest="40"
                                Margin="4">
                            <Label Text="15" FontSize="14" TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray700}"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{StaticResource SurfaceDark}"
                                HeightRequest="40"
                                WidthRequest="40"
                                Margin="4">
                            <Label Text="16" FontSize="14" TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray700}"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{StaticResource SurfaceDark}"
                                HeightRequest="40"
                                WidthRequest="40"
                                Margin="4">
                            <Label Text="17" FontSize="14" TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray700}"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{StaticResource SurfaceDark}"
                                HeightRequest="40"
                                WidthRequest="40"
                                Margin="4">
                            <Label Text="18" FontSize="14" TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </FlexLayout>
                </VerticalStackLayout>

                <!-- Progress Card -->
                <Border StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        BackgroundColor="{StaticResource SurfaceDark}"
                        Padding="20">
                    <VerticalStackLayout Spacing="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Progression"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource White}"/>
                            <Label Grid.Column="1"
                                   Text="{Binding Challenge.ProgressPercentage, StringFormat='{0:F0}%'}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"/>
                        </Grid>
                        
                        <!-- Progress Bar -->
                        <Grid HeightRequest="12">
                            <BoxView BackgroundColor="{StaticResource Gray800}" CornerRadius="6"/>
                            <BoxView BackgroundColor="{StaticResource Primary}" 
                                     CornerRadius="6"
                                     HorizontalOptions="Start"
                                     WidthRequest="100"/>
                        </Grid>
                        
                        <Label Text="{Binding Challenge.RemainingDays, StringFormat='{0} jours restants'}"
                               FontSize="14"
                               TextColor="{StaticResource Gray400}"
                               HorizontalOptions="End"/>
                        
                        <BoxView HeightRequest="1" Color="{StaticResource Gray700}" Margin="0,8"/>
                        
                        <!-- Today's Task -->
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="AUJOURD'HUI"
                                       FontSize="10"
                                       TextColor="{StaticResource Gray500}"/>
                                <Label Text="{Binding Challenge.TodayTask}"
                                       FontSize="16"
                                       TextColor="{StaticResource White}"/>
                            </VerticalStackLayout>
                            
                            <Button Grid.Column="1"
                                    Text="Commencer"
                                    Command="{Binding StartTodayTaskCommand}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="{StaticResource White}"
                                    FontSize="14"
                                    FontAttributes="Bold"
                                    HeightRequest="40"
                                    CornerRadius="20"
                                    Padding="20,0"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Bottom Spacing -->
                <BoxView HeightRequest="100" Color="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
